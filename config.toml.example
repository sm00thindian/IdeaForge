# IdeaForge configuration
# Copy to ~/.config/ideaforge/config.toml

archive = "~/IdeaForge"

[llm]
backend = "auto"         # auto | ollama | grok | claude  (auto prefers Grok)
ollama_model = "llama3.1"
grok_model = "grok-4.3"   # grok-4-1-fast-reasoning for faster/cheaper
claude_model = "claude-sonnet-4-20250514"

[whisper]
backend = "auto"         # auto | mlx | faster  (auto uses mlx on Apple Silicon)
model = "small"          # tiny | base | small | medium | large-v3
device = "cpu"           # for faster-whisper fallback: cpu | cuda
compute_type = "int8"
beam_size = 1            # faster-whisper only; 1 is fastest
language = "en"          # force English (omit for auto-detect)

[processing]
mode = "meeting"         # meeting | creative | auto
output_format = "both"   # md | json | both
diarize = false
min_file_size_bytes = 50000
merge_chunks = true          # join consecutive recorder splits (e.g. 15 min max)
chunk_gap_seconds = 30       # max gap between chunk end and next start
merge_min_chunk_seconds = 600  # prior chunk must be this long to merge (filters short clips)
max_parallel_sessions = 2      # 1 = sequential; 2+ pipelines sessions (GPU serialized, LLM overlaps)

[diarization]
# Hugging Face token for pyannote models (or set HF_TOKEN env var)
# hf_token = "hf_..."
min_speakers = 2        # hint for 2-person recordings (optional)
# max_speakers = 2

# Optional: override pyannote labels in the saved transcript (Grok infers names by default)
# [speakers.map]
# SPEAKER_00 = "Kilynn"
# SPEAKER_01 = "Alex"

[daemon]
poll_interval_seconds = 5   # how often to check /Volumes
settle_seconds = 5          # wait after mount before processing
delete_after_copy = true    # remove recordings from device after verified local copy
unmount_after_ingest = true # eject volume after all files are copied and verified locally
notify = true               # macOS notification when pipeline finishes
sync_device_clock = true    # fix recset.txt before ingest (before unmount)
clock_skew_threshold_seconds = 60  # only write when skew exceeds this
notify_on_failure = false   # macOS alert when a pipeline session fails (opt-in)

# Menu bar progress UI (optional):
#   ./scripts/install-menubar.sh
# Reads ~/Library/Application Support/IdeaForge/status.json

[export]
# Off by default — enable what you use (opt-in)
reminders = false
reminders_list = "IdeaForge"
obsidian = false
# obsidian_vault = "~/Documents/Obsidian/MyVault"
obsidian_note = "IdeaForge/Action Items.md"